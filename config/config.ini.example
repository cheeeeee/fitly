# Log level: DEBUG, INFO, WARNING, ERROR
level = DEBUG
# Path to the rotating log file
log_file = ./config/log.log
# Maximum log file size in bytes before rotating (default 10 MB)
log_max_bytes = 10000000
# Number of rotated log files to keep
log_backup_count = 5

[cron]
# Set to True to enable hourly background data refresh
hourly_pull = False
# Which hour(s) to run the refresh (APScheduler cron format, default '*' = every hour)
# Examples: '2' = 2am only, '*/2' = every 2 hours, '1,13' = 1am and 1pm
refresh_hour = *

[settings]
# App password (used to protect settings page)
password =
# Number of gunicorn worker processes (overridden by [server] gunicorn_workers)
gunicorn_workers = 3

