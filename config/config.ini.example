[logger]
# Log level: DEBUG, INFO, WARNING, ERROR
level = DEBUG

[cron]
# Set to True to enable hourly background data refresh
hourly_pull = False

[settings]
# App password (used to protect settings page)
password =
# Number of gunicorn worker processes
gunicorn_workers = 3

# ---------------------------------------------------------------------------
# Spotify - leave client_id and client_secret blank to disable
# Restart is required after connecting via settings page for stream to work
# ---------------------------------------------------------------------------
[spotify]
client_id =
client_secret =
redirect_uri =
# Range of % of song duration that counts as a 'Skip' for model training
skip_min_threshold = .05
skip_max_threshold = .80
# Min seconds a song must play before being saved to db (ignores quick skips)
min_secs_listened = 15
# Polling interval in seconds for the Spotify 'currently playing' endpoint
# .5 = 2 requests/second; reduce if hitting API rate limits
poll_interval_seconds = .5

# ---------------------------------------------------------------------------
# Peloton - leave username/password blank to disable
# ---------------------------------------------------------------------------
[peloton]
username =
password =

# ---------------------------------------------------------------------------
# Stryd - leave username/password blank to disable
# ---------------------------------------------------------------------------
[stryd]
username =
password =
compare_against_age = 1
compare_against_gender = 1
compare_against_race_event = 1

# ---------------------------------------------------------------------------
# Strava - required for activity import
# ---------------------------------------------------------------------------
[strava]
# Only import activities after this date (ISO 8601)
activities_after_date = 2018-01-01T00:00:00Z
client_id =
client_secret =
redirect_uri = http://127.0.0.1:8050/settings?strava

# ---------------------------------------------------------------------------
# Oura - leave client_id and client_secret blank to disable
# ---------------------------------------------------------------------------
[oura]
redirect_uri = http://127.0.0.1:8050/settings?oura
client_id =
client_secret =
# How many days back to pull/refresh on each cron run
days_back = 7
# Chart color theme
white = rgb(220, 220, 220)
teal = rgb(134, 201, 250)
light_blue = rgb(85, 139, 189)
dark_blue = rgb(43, 70, 119)
orange = rgb(234, 109, 95)

# ---------------------------------------------------------------------------
# Withings - leave client_id and client_secret blank to disable
# ---------------------------------------------------------------------------
[withings]
redirect_uri = http://127.0.0.1:8050/settings?withings
client_id =
client_secret =

# ---------------------------------------------------------------------------
# Nextcloud (for Fitbod CSV sync) - leave fields blank to disable
# ---------------------------------------------------------------------------
[nextcloud]
url =
username =
password =
fitbod_path =

[timezone]
timezone = America/New_York

# ---------------------------------------------------------------------------
# Processing - controls multiprocessing behavior for activity imports
# ---------------------------------------------------------------------------
[processing]
# Number of parallel workers for activity parsing.
# 'auto' uses half of available CPU cores (min 1), which is safe for most setups.
# Increase on machines with fast storage (SSD/NVMe) for faster imports.
# Set to 1 to disable parallelism entirely.
workers = auto

# Serialize all database writes behind a lock (true/false).
# true  - One worker writes at a time (safe for slow SD card storage, e.g. Raspberry Pi).
# false - Workers write concurrently, relying on SQLite WAL mode + retry logic.
#         Only set to false if your database lives on fast storage (SSD/NVMe).
serialize_db_writes = true

[dashboard]
# Page transition animation duration in milliseconds
transition = 2000