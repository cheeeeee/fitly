# Range of % of song duration that counts as a 'Skip' for model training
skip_min_threshold = .05
skip_max_threshold = .80
# Min seconds a song must play before being saved to db (ignores quick skips)
min_secs_listened = 15
# Polling interval in seconds for the Spotify 'currently playing' endpoint
# .5 = 2 requests/second; reduce if hitting API rate limits
poll_interval_seconds = .5

